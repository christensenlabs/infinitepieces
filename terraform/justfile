# Plan shared infrastructure
shared-plan:
    cd shared && tofu plan

# Apply shared infrastructure
shared-apply:
    cd shared && tofu apply

# Plan a specific environment
plan env:
    cd envs/{{env}} && tofu plan

# Apply a specific environment
apply env:
    cd envs/{{env}} && tofu apply

# Convenience aliases
dev-plan: (plan "dev")
dev-apply: (apply "dev")
prod-plan: (plan "prod")
prod-apply: (apply "prod")
