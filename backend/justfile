ecr_repo := "infinitepieces-backend"
aws_region := "us-east-1"

# Run locally (Spring Boot, local profile)
dev:
    ./gradlew bootRun --args='--spring.profiles.active=local'

# Build jar
build:
    ./gradlew build

# Lint Kotlin sources
lint:
    ./gradlew ktlintCheck

# Autofix Kotlin lint issues
lint-fix:
    ./gradlew ktlintFormat

# Generate JOOQ code from migration SQL files
jooq:
    ./gradlew generateJooq

# Build Docker image (runs JOOQ codegen first, then builds inside Docker)
docker-build: jooq
    docker build -t {{ecr_repo}} .

# Run in Docker locally (detached, on the project network)
docker-up: docker-build
    docker rm -f $CLABS_INFINITEPIECES_PROJECT_NAME-backend 2>/dev/null || true
    docker run -d -p 8080:8080 -p 5005:5005 --name $CLABS_INFINITEPIECES_PROJECT_NAME-backend \
        --network ${CLABS_INFINITEPIECES_PROJECT_NAME}_default \
        -e SPRING_DATASOURCE_URL=jdbc:postgresql://$CLABS_INFINITEPIECES_PROJECT_NAME-postgres:5432/infinitepieces \
        -e SPRING_FLYWAY_URL=jdbc:postgresql://$CLABS_INFINITEPIECES_PROJECT_NAME-postgres:5432/infinitepieces \
        -e CLABS_INFINITEPIECES_DB_PASSWORD=$CLABS_INFINITEPIECES_DB_PASSWORD \
        $(if [ -n "$GOOGLE_APPLICATION_CREDENTIALS" ] && [ -f "$GOOGLE_APPLICATION_CREDENTIALS" ]; then echo "-e GOOGLE_APPLICATION_CREDENTIALS=/firebase/service-account.json -v $GOOGLE_APPLICATION_CREDENTIALS:/firebase/service-account.json:ro"; fi) \
        -v $(pwd)/../database/migrations:/migrations:ro \
        -e SPRING_FLYWAY_LOCATIONS=filesystem:/migrations \
        {{ecr_repo}}
    @echo "==> Backend running at http://localhost:8080 (docker stop $CLABS_INFINITEPIECES_PROJECT_NAME-backend to stop)"

# Deploy to ECS (build, push to ECR, force new deployment)
deploy: docker-build
    @echo "==> Logging into ECR..."
    aws ecr get-login-password --region {{aws_region}} | docker login --username AWS --password-stdin $CLABS_AWS_ACCOUNT_ID.dkr.ecr.{{aws_region}}.amazonaws.com
    @echo "==> Tagging and pushing image..."
    docker tag {{ecr_repo}}:latest $CLABS_AWS_ACCOUNT_ID.dkr.ecr.{{aws_region}}.amazonaws.com/{{ecr_repo}}:latest
    docker push $CLABS_AWS_ACCOUNT_ID.dkr.ecr.{{aws_region}}.amazonaws.com/{{ecr_repo}}:latest
    @echo "==> Forcing new ECS deployment..."
    aws ecs update-service --cluster infinitepieces --service infinitepieces-backend --force-new-deployment --region {{aws_region}} > /dev/null
    @echo "==> Backend deploy complete!"
