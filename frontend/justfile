# Run dev server
dev:
    npm run dev

# Build for production
build:
    npm run build

# Deploy to S3 + CloudFront
# Usage: just deploy <env>
deploy env: build
    #!/usr/bin/env bash
    set -euo pipefail
    BUCKET=$(cd ../terraform/envs/{{env}} && tofu output -raw s3_bucket)
    DIST_ID=$(cd ../terraform/envs/{{env}} && tofu output -raw cloudfront_distribution_id)
    echo "==> Syncing dist/ to S3 bucket $BUCKET..."
    aws s3 sync dist s3://$BUCKET --delete
    echo "==> Invalidating CloudFront distribution $DIST_ID..."
    aws cloudfront create-invalidation --distribution-id $DIST_ID --paths "/*"
    echo "==> Frontend deploy complete ({{env}})!"
